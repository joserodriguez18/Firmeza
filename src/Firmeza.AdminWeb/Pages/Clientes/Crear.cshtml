@page
@model Firmeza.AdminWeb.Pages.Clientes.CrearModel
@{
    ViewData["Title"] = "Registrar Cliente";
}

<div class="container" style="max-width: 800px;">
    <div class="mb-3">
        <a href="/Clientes/Index" class="text-muted text-decoration-none small"><i class="bi bi-arrow-left"></i> Volver al Directorio</a>
    </div>

    <h2 class="fw-bold text-dark mb-4">Alta de Cliente Comercial</h2>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger shadow-sm border-start border-danger border-4 small" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i> @Model.ErrorMessage
        </div>
    }

    <div class="card border-0 shadow-sm p-4 bg-white">
        <form method="post">
            <div class="row g-3">
                <div class="col-md-12">
                    <label asp-for="Input.NombreCompleto" class="form-label fw-semibold text-muted small">Nombre o Razón Social</label>
                    <input asp-for="Input.NombreCompleto" class="form-control bg-light" placeholder="Ej. Juan Pérez u Ferretería Central" />
                    <span asp-validation-for="Input.NombreCompleto" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Input.Documento" class="form-label fw-semibold text-muted small">Documento / NIT / Cédula</label>
                    <input asp-for="Input.Documento" class="form-control bg-light" placeholder="Ej. 10203040" />
                    <span asp-validation-for="Input.Documento" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Input.Telefono" class="form-label fw-semibold text-muted small">Teléfono de Contacto</label>
                    <input asp-for="Input.Telefono" class="form-control bg-light" placeholder="Ej. 3101234567" />
                    <span asp-validation-for="Input.Telefono" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Input.Edad" class="form-label fw-semibold text-muted small">Edad del Titular</label>
                    <input asp-for="Input.Edad" class="form-control bg-light" type="number" placeholder="Mínimo 18" />
                    <span asp-validation-for="Input.Edad" class="text-danger small"></span>
                </div>

                <div class="col-md-8">
                    <label asp-for="Input.Email" class="form-label fw-semibold text-muted small">Correo Electrónico Corporativo</label>
                    <input asp-for="Input.Email" class="form-control bg-light" placeholder="cliente@correo.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="col-md-12">
                    <label asp-for="Input.Password" class="form-label fw-semibold text-muted small">Asignar Contraseña de Acceso (Para Portal Blazor de Prueba 3)</label>
                    <input asp-for="Input.Password" type="password" class="form-control bg-light" placeholder="Mínimo 6 caracteres" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                <a href="/Clientes/Index" class="btn btn-light fw-semibold text-muted px-4">Cancelar</a>
                <button type="submit" class="btn btn-dark fw-bold text-warning px-4">Dar de Alta</button>
            </div>
        </form>
    </div>
</div>
