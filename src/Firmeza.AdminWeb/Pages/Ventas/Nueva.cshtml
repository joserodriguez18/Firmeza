@page
@model Firmeza.AdminWeb.Pages.Ventas.NuevaModel
@{
    ViewData["Title"] = "Nueva Venta Multiproducto";
}

<div class="container-fluid" style="max-width: 1000px;">
    <div class="mb-3">
        <a href="/Ventas/Index" class="text-muted text-decoration-none small"><i class="bi bi-arrow-left"></i> Volver al
            Registro</a>
    </div>

    <h2 class="fw-bold text-dark mb-4">Despacho de Materiales (Venta Múltiple)</h2>

    @if (!string.IsNullOrEmpty(Model.ErrorVenta))
    {
        <div class="alert alert-danger shadow-sm border-start border-danger border-4 small" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i> @Model.ErrorVenta
        </div>
    }

    <form method="post" id="formVenta">
        <!-- Input oculto donde guardaremos el JSON para el servidor -->
        <input type="hidden" id="inputProductosJson" asp-for="ProductosJson"/>

        <div class="row g-4">
            <!-- Columna Izquierda: Datos y Selector de Productos -->
            <div class="col-md-5">
                <div class="card border-0 shadow-sm p-4 bg-white mb-3">
                    <h5 class="fw-bold text-secondary mb-3">1. Datos de la Operación</h5>

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted small">Seleccionar Cliente</label>
                        <select asp-for="ClienteIdSeleccionado" class="form-select bg-light" required>
                            <option value="">-- Seleccione un comprador --</option>
                            @foreach (var c in Model.Clientes)
                            {
                                <option value="@c.Id">@c.Usuario.NombreCompleto (@c.Documento)</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="card border-0 shadow-sm p-4 bg-white">
                    <h5 class="fw-bold text-secondary mb-3">2. Añadir Materiales</h5>

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted small">Material / Producto</label>
                        <select id="selectProducto" class="form-select bg-light">
                            <option value="">-- Seleccione del inventario --</option>
                            @foreach (var p in Model.Productos)
                            {
                                <option value="@p.Id" data-nombre="@p.Nombre" data-precio="@p.Precio">
                                    @p.Nombre (@p.Precio.ToString("C0"))
                                </option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted small">Cantidad</label>
                        <input id="inputCantidad" type="number" class="form-control bg-light" min="1" value="1"/>
                    </div>

                    <button type="button" id="btnAgregar" class="btn btn-dark w-100 fw-bold text-warning">
                        <i class="bi bi-plus-circle me-1"></i> Agregar al Carrito
                    </button>
                </div>
            </div>

            <!-- Columna Derecha: El Carrito de Compras en tiempo real -->
            <div class="col-md-7">
                <div class="card border-0 shadow-sm p-4 bg-white h-100 d-flex flex-column">
                    <h5 class="fw-bold text-secondary mb-3">3. Resumen del Carrito</h5>

                    <div class="table-responsive flex-grow-1">
                        <table class="table table-hover align-middle" id="tablaCarrito">
                            <thead class="table-light small text-uppercase">
                            <tr>
                                <th>Material</th>
                                <th class="text-center">Cant.</th>
                                <th class="text-end">Precio U.</th>
                                <th class="text-end">Subtotal</th>
                                <th class="text-center">Acción</th>
                            </tr>
                            </thead>
                            <tbody>
                            <tr id="filaVacia">
                                <td colspan="5" class="text-center py-4 text-muted small">
                                    No hay productos agregados a esta orden todavía.
                                </td>
                            </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Totales Informativos en Pantalla -->
                    <div class="border-top pt-3 mt-3" style="font-size: 0.95rem;">
                        <div class="d-flex justify-content-between text-muted mb-1">
                            <span>Subtotal:</span>
                            <span id="txtSubtotal">$0.00</span>
                        </div>
                        <div class="d-flex justify-content-between text-muted mb-2">
                            <span>IVA (19%):</span>
                            <span id="txtIva">$0.00</span>
                        </div>
                        <div class="d-flex justify-content-between fw-bold text-dark fs-5">
                            <span>Total a Facturar:</span>
                            <span id="txtTotal" class="text-success">$0.00</span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a href="/Ventas/Index" class="btn btn-light fw-semibold text-muted px-4">Cancelar</a>
                        <button type="submit" class="btn btn-success fw-bold px-4 text-white">Procesar Venta</button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // Array global en JavaScript para controlar el estado de la compra
        let carrito = [];

        const btnAgregar = document.getElementById('btnAgregar');
        const selectProducto = document.getElementById('selectProducto');
        const inputCantidad = document.getElementById('inputCantidad');
        const tablaCarrito = document.getElementById('tablaCarrito').getElementsByTagName('tbody')[0];
        const filaVacia = document.getElementById('filaVacia');
        const formVenta = document.getElementById('formVenta');

        btnAgregar.addEventListener('click', () => {
            const productoId = parseInt(selectProducto.value);
            const cantidad = parseInt(inputCantidad.value);

            if (!productoId || cantidad <= 0) {
                alert('Por favor selecciona un producto y una cantidad válida.');
                return;
            }

            const optionSeleccionada = selectProducto.options[selectProducto.selectedIndex];
            const nombre = optionSeleccionada.getAttribute('data-nombre');
            const precio = parseFloat(optionSeleccionada.getAttribute('data-precio'));

            // Validar si el producto ya fue agregado para sumar la cantidad en vez de duplicar fila
            const elementoExistente = carrito.find(item => item.productoId === productoId);
            if (elementoExistente) {
                elementoExistente.cantidad += cantidad;
            } else {
                carrito.push({productoId, nombre, precio, cantidad});
            }

            // Resetear inputs auxiliares
            selectProducto.value = '';
            inputCantidad.value = 1;

            renderizarCarrito();
        });

        function eliminarItem(productoId) {
            carrito = carrito.filter(item => item.productoId !== productoId);
            renderizarCarrito();
        }

        function renderizarCarrito() {
            // Limpiar filas viejas de la tabla manteniendo solo la estructura
            tablaCarrito.innerHTML = '';

            if (carrito.length === 0) {
                tablaCarrito.appendChild(filaVacia);
                actualizarTotales(0);
                return;
            }

            let subtotalGeneral = 0;

            carrito.forEach(item => {
                const subtotalItem = item.precio * item.cantidad;
                subtotalGeneral += subtotalItem;

                const fila = document.createElement('tr');
                fila.innerHTML = `
                    <td class="fw-bold text-dark small">${item.nombre}</td>
                    <td class="text-center badge bg-dark-subtle text-dark m-2">${item.cantidad} Uds</td>
                    <td class="text-end">$${item.precio.toLocaleString('es-CO', {minimumFractionDigits: 2})}</td>
                    <td class="text-end fw-semibold">$${subtotalItem.toLocaleString('es-CO', {minimumFractionDigits: 2})}</td>
                    <td class="text-center">
                        <button type="button" class="btn btn-sm btn-link text-danger p-0" onclick="eliminarItem(${item.productoId})">
                            <i class="bi bi-x-circle-fill"></i>
                        </button>
                    </td>
                `;
                tablaCarrito.appendChild(fila);
            });

            actualizarTotales(subtotalGeneral);
        }

        function actualizarTotales(subtotal) {
            const iva = subtotal * 0.19;
            const total = subtotal + iva;

            document.getElementById('txtSubtotal').innerText = `$${subtotal.toLocaleString('es-CO', {minimumFractionDigits: 2})}`;
            document.getElementById('txtIva').innerText = `$${iva.toLocaleString('es-CO', {minimumFractionDigits: 2})}`;
            document.getElementById('txtTotal').innerText = `$${total.toLocaleString('es-CO', {minimumFractionDigits: 2})}`;

            // --- ESTA ES LA LÍNEA QUE FALTABA PARA ENLAZAR CON C# ---
            document.getElementById('inputProductosJson').value = JSON.stringify(carrito);
        }
    </script>
}