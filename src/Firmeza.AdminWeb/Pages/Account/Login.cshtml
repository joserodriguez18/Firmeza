@page
@model Firmeza.AdminWeb.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null; // No usa la barra lateral, es una pantalla limpia
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Firmeza</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { background: linear-gradient(135deg, #212529 0%, #343a40 100%); min-height: 100vh; }
        .card-login { border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.3); }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center">

    <div class="container" style="max-width: 450px;">
        <div class="card card-login border-0 p-4 bg-white">
            <div class="text-center mb-4">
                <h2 class="fw-bold text-dark m-0">Firmeza SAS</h2>
                <small class="text-muted text-uppercase fw-semibold tracking-wider">Panel Administrativo</small>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger p-2 small text-center" role="alert">
                    @Model.ErrorMessage
                </div>
            }

            <form method="post">
                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label font-weight-bold small text-muted">Correo Electrónico</label>
                    <input asp-for="Input.Email" class="form-control" placeholder="nombre@firmeza.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.Password" class="form-label font-weight-bold small text-muted">Contraseña</label>
                    <input asp-for="Input.Password" class="form-control" type="password" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-dark w-100 py-2 fw-bold text-warning">
                    Ingresar al Sistema
                </button>
            </form>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
