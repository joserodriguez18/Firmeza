@page
@model Firmeza.AdminWeb.Pages.Documentos.IndexModel
@{
    ViewData["Title"] = "Documentos";
    var errores = ViewData["Errores"] as IEnumerable<string> ?? Enumerable.Empty<string>();
}

<div class="row g-4">
    <div class="col-lg-6">
        <div class="panel-surface p-4">
            <h4 class="mb-3">Carga masiva</h4>
            <form method="post" enctype="multipart/form-data" asp-page-handler="Importar">
                <div class="mb-3">
                    <label class="form-label">Archivo Excel desnormalizado</label>
                    <input asp-for="ArchivoExcel" type="file" class="form-control" accept=".xlsx" />
                </div>
                <button class="btn btn-primary" type="submit">Importar</button>
            </form>
            @if (!string.IsNullOrWhiteSpace(Model.Mensaje))
            {
                <div class="alert alert-success mt-3">@Model.Mensaje</div>
            }
            @if (errores.Any())
            {
                <div class="alert alert-warning mt-3">
                    <strong>Inconsistencias</strong>
                    <ul class="mb-0">
                        @foreach (var error in errores)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Error))
            {
                <div class="alert alert-danger mt-3">@Model.Error</div>
            }
        </div>
    </div>
    <div class="col-lg-6">
        <div class="panel-surface p-4">
            <h4 class="mb-3">Exportaciones</h4>
            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-outline-primary" asp-page-handler="ExportarProductosExcel">Exportar productos Excel</a>
                <a class="btn btn-outline-secondary" asp-page-handler="ExportarClientesPdf">Exportar clientes PDF</a>
                <a class="btn btn-outline-dark" asp-page-handler="ExportarVentasExcel">Exportar ventas Excel</a>
            </div>
            <hr />
            <p class="text-muted mb-2">Recibos generados en wwwroot/recibos:</p>
            @foreach (var nombre in Model.Recibos)
            {
                <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                    <span>@nombre</span>
                    <a class="btn btn-sm btn-link" asp-page-handler="DescargarRecibo" asp-route-nombre="@nombre">Descargar</a>
                </div>
            }
        </div>
    </div>
</div>
