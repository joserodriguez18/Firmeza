<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Firmeza Administrativo</title>
    <!-- Bootstrap 5 CDN -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
</head>
<body>

<!-- BARRA LATERAL (Sidebar - Task 5) -->
<div class="sidebar d-flex flex-column p-3 text-white">
    <a href="/Dashboard"
       class="d-flex align-items-center mb-4 me-md-auto text-white text-decoration-none gap-2 fs-4 fw-bold">
        <i class="bi bi-building-fill text-warning"></i>
        <span>Firmeza SAS</span>
    </a>
    <hr>
    <ul class="nav nav-pills flex-column mb-auto gap-1">
        <li>
            <a href="/Dashboard" class="nav-link">
                <i class="bi bi-speedometer2"></i> Inicio / Dashboard
            </a>
        </li>
        <li>
            <a href="/Productos/Index" class="nav-link">
                <i class="bi bi-box-seam"></i> Productos
            </a>
        </li>
        <li>
            <a href="/Clientes/Index" class="nav-link">
                <i class="bi bi-people"></i> Clientes
            </a>
        </li>
        <li>
            <a href="/Ventas/Index" class="nav-link">
                <i class="bi bi-cart-check"></i> Ventas
            </a>
        </li>
        <li>
            <a href="/Documentos/Index" class="nav-link">
                <i class="bi bi-file-earmark-arrow-down"></i> Documentos
            </a>
        </li>
    </ul>
    <!-- Perfil / Cerrar Sesión Oficial (Task 4) -->
    <hr>
    <div class="d-flex flex-column gap-2">
        <div class="d-flex align-items-center text-white small px-2">
            <i class="bi bi-person-circle fs-5 me-2 text-warning"></i>
            <span class="text-truncate fw-semibold">admin@firmeza.com</span>
        </div>
        <!-- Formulario POST para invocar el Logout de forma segura -->
        <form method="post" asp-page="/Account/Logout" class="m-0 p-0">
            <button type="submit" class="btn btn-sm btn-outline-danger w-100 text-start d-flex align-items-center gap-2 border-0 py-2 px-2">
                <i class="bi bi-box-arrow-left"></i>
                <span>Cerrar Sesión</span>
            </button>
        </form>
    </div>
    @* <div class="dropdown"> *@
    @*         <span class="d-flex align-items-center text-white text-decoration-none"> *@
    @*             <i class="bi bi-person-circle fs-4 me-2"></i> *@
    @*             <strong>Admin Firmeza</strong> *@
    @*         </span> *@
    @* </div> *@
</div>

<!-- CONTENIDO PRINCIPAL -->
<div class="main-content d-flex flex-column">
    <!-- Barra superior -->
    <header class="navbar-custom d-flex justify-content-between align-items-center mb-4 rounded border">
        <h5 class="m-0 text-muted">Módulo Administrativo Base</h5>
        <span class="badge bg-success p-2">Conectado a PostgreSQL</span>
    </header>

    <!-- Páginas Razor dinámicas -->
    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>

    <!-- PIE DE PÁGINA (Task 9) -->
    <footer class="text-center text-muted mt-5 rounded border">
        <div>&copy; 2026 - Firmeza SAS - Panel de Control Interno</div>
    </footer>
</div>

<!-- Bootstrap 5 JS Bundle -->
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>

</html>
